{
  "name": "polar-footer",
  "version": "1.0.0",
  "description": "Reusable Polr footer package with web component and React entrypoint",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {},
  "keywords": ["footer", "web-component", "react", "polr", "branding"],
  "license": "MIT"
}
